# BIGIL Threat Intelligence Configuration
# Copy to .env and fill in your keys, then restart the server.

ABUSEIPDB_API_KEY=YOUR_ABUSEIPDB_API_KEY
OTX_API_KEY=YOUR_ALIENVAULT_OTX_API_KEY
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY
MALWAREBAZAAR_API_KEY=YOUR_MALWAREBAZAAR_API_KEY
URLHAUS_API_KEY=YOUR_URLHAUS_API_KEY

# Flask
SECRET_KEY=YOUR_SECRET_KEY

# Database
DATABASE_URL=sqlite:///instance/bigil.db

# Environment
FLASK_ENV=development
FLASK_DEBUG=True
